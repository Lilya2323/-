import tkinter as tk
from tkinter import ttk, messagebox
import random
import string
import pyperclip  

def generate_password():
    length = int(length_var.get())
    use_letters = letters_var.get()
    use_digits = digits_var.get()
    use_symbols = symbols_var.get()

    if not (use_letters or use_digits or use_symbols):
        messagebox.showwarning("Ошибка", "Выберите хотя бы один тип символов!")
        return

    chars = ''
    if use_letters:
        chars += string.ascii_letters
    if use_digits:
        chars += string.digits
    if use_symbols:
        chars += string.punctuation

    password = ''.join(random.choices(chars, k=length))
    result_entry.delete(0, tk.END)
    result_entry.insert(0, password)

def copy_to_clipboard():
    password = result_entry.get()
    if password:
        pyperclip.copy(password)
        messagebox.showinfo("Успех", "Пароль скопирован в буфер обмена!")

root = tk.Tk()
root.title("Генератор паролей")
root.geometry("400x250")
root.resizable(False, False)

tk.Label(root, text="Длина пароля:").pack(pady=5)
length_var = tk.IntVar(value=10)
length_slider = ttk.Scale(root, from_=4, to=32, variable=length_var, orient='horizontal')
length_slider.pack(pady=5)

options_frame = tk.Frame(root)
options_frame.pack(pady=10)

letters_var = tk.BooleanVar(value=True)
digits_var = tk.BooleanVar(value=True)
symbols_var = tk.BooleanVar(value=False)

tk.Checkbutton(options_frame, text="Буквы", variable=letters_var).grid(row=0, column=0, padx=5)
tk.Checkbutton(options_frame, text="Цифры", variable=digits_var).grid(row=0, column=1, padx=5)
tk.Checkbutton(options_frame, text="Символы", variable=symbols_var).grid(row=0, column=2, padx=5)

tk.Button(root, text="Сгенерировать", command=generate_password).pack(pady=10)

result_entry = tk.Entry(root, width=40, font=('Arial', 12))
result_entry.pack(pady=5)

try:
    import pyperclip
    tk.Button(root, text="Копировать", command=copy_to_clipboard).pack(pady=5)
except ImportError:
    pass

root.mainloop()
